{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "lib": ["ES2022", "DOM"],
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@chapeaux/cpx-store": ["./vendor/cpx-store.ts"]
    }
  },
  "include": ["data/**/*.ts", "comidas-matching-store.ts", "vendor/*.ts", "client/*.ts"]
}
